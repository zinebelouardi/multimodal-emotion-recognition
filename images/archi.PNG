.ͼk .tok-keyword {color: blue;}
.ͼk .tok-labelName {color: #833FBA;}
.ͼk .tok-literal {color: #833FBA;}
.ͼk .tok-invalid {background-color: rgba(255, 0, 0, 0.1); color: red;}
.ͼk .tok-operator {color: rgb(104, 118, 135);}
.ͼk .tok-string {color: rgb(3, 106, 7);}
.ͼk .tok-comment {color: rgb(76, 136, 107);}
.ͼk .tok-attributeValue {color: rgb(49, 132, 149);}
.ͼk .tok-function {color: #0000A2;}
.ͼk .tok-heading {color: rgb(12, 7, 255);}
.ͼk .tok-list {color: rgb(185, 6, 144);}
.ͼj .cm-gutters {background-color: transparent; border-right-color: transparent; background: #f0f0f0; color: #333;}
.ͼj .cm-foldPlaceholder {background-color: #6B72E6;}
.ͼj {background-color: #FFFFFF; color: black;}
.ͼj .cm-cursor, .ͼj .cm-dropCursor {color: black;}
.ͼj.cm-focused > .cm-scroller > .cm-selectionLayer .cm-selectionBackground, .ͼj .cm-selectionBackground, .ͼj .cm-content ::selection, .ͼj .cm-searchMatch.cm-searchMatch.cm-searchMatch-selected {background: rgb(181, 213, 255);}
.ͼj.cm-focused .cm-matchingBracket, .ͼj.cm-focused .cm-nonmatchingBracket {margin: 0; outline: 1px solid rgb(192, 192, 192);}
.ͼj .cm-activeLine {background: rgba(0, 0, 0, 0.07);}
.ͼj .cm-activeLineGutter {background-color: #dcdcdc;}
.ͼj .cm-selectionMatch.cm-selectionMatch, .ͼj .cm-searchMatch.cm-searchMatch {background: rgba(250, 250, 255, 0.5); outline: 1px solid rgb(200, 200, 250); margin: 0;}
.ͼi .cm-tooltip {--font-size: 12px; --source-font-family: Lucida Console,Source Code Pro,monospace; --line-height: 1.6;}
.ͼ6 {height: 100%; text-rendering: optimizeSpeed; font-variant-numeric: slashed-zero;}
.ͼ6.cm-editor.cm-focused:not(:focus-visible) {outline: none;}
.ͼ6 .cm-panels {background-color: var(--bg-secondary-themed);}
.ͼ6 .cm-panel-bottom {border-top: 1px solid var(--border-primary-themed);}
.ͼ6 .cm-panel.cm-search label {display: inline-flex; align-items: center; font-weight: normal;}
.ͼ6 .cm-selectionLayer {z-index: -10;}
.ͼ6 .cm-gutters {border-right: none; flex-shrink: 0;}
.ͼ6 .cm-foldGutter .cm-gutterElement > span {border: 1px solid transparent; border-radius: 3px; display: inline-flex; flex-direction: column; justify-content: center; color: rgba(109, 109, 109, 0.7);}
.ͼ6 .cm-lineNumbers .cm-gutterElement {padding: 0; user-select: none;}
.ͼ6:not(.cm-focused) > .cm-scroller > .cm-cursorLayer .cm-cursor {display: block; opacity: 0.2;}
.ͼ6 .cm-cursor, .ͼ6 .cm-dropCursor {border-width: 2px; margin-left: -1px; border-left-color: inherit;}
.ͼ6 .cm-tooltip-hover {border: none;}
