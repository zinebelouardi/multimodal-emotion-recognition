.ͼ1 [class^="cm-wf-debug-part-"] {--color-bg: hsl(var(--color-bg-h) var(--color-bg-s) var(--color-bg-l)); --color-bg-main: hsl(var(--color-bg-h) var(--color-bg-s) var(--color-bg-l)); --color-bg-secondary: hsl(var(--color-bg-h) var(--color-bg-s) calc(var(--color-bg-l) + 20%)); background: var(--color-bg); position: relative;}
.ͼ1 [class$="-ix-0"] {--color-bg-h: 21; --color-bg-s: 89%; --color-bg-l: 76%;}
.ͼ1 [class$="-ix-1"] {--color-bg-h: 94; --color-bg-s: 38%; --color-bg-l: 79%;}
.ͼ1 [class$="-ix-2"] {--color-bg-h: 42; --color-bg-s: 93%; --color-bg-l: 84%;}
.ͼ1 [class$="-ix-3"] {--color-bg-h: 198; --color-bg-s: 61%; --color-bg-l: 59%;}
.ͼ1 [class$="-ix-4"] {--color-bg-h: 359; --color-bg-s: 94%; --color-bg-l: 82%;}
.ͼ1 [class$="-ix-5"] {--color-bg-h: 162; --color-bg-s: 43%; --color-bg-l: 66%;}
.ͼ1 [class$="-ix-6"] {--color-bg-h: 20; --color-bg-s: 94%; --color-bg-l: 83%;}
.ͼ1 [class$="-ix-7"] {--color-bg-h: 208; --color-bg-s: 25%; --color-bg-l: 65%;}
.ͼ1 [class$="-ix-8"] {--color-bg-h: 33; --color-bg-s: 94%; --color-bg-l: 75%;}
.ͼ1 [class$="-ix-9"] {--color-bg-h: 178; --color-bg-s: 30%; --color-bg-l: 63%;}
.ͼ1 [class^="cm-wf-debug-part-"]::before {position: fixed; display: block; z-index: 100; right: 50px; top: 120px; padding: 10px 14px; max-width: 400px; text-indent: 0; line-height: 2; background: var(--color-bg); border-radius: 6px; box-shadow: 0 10px 20px rgba(0, 0, 0, 0.19), 0 6px 6px rgba(0, 0, 0, 0.23); opacity: 0; content: attr(data-debug-tooltip);}
.ͼ1 [class^="cm-wf-debug-part-"]:hover::before {opacity: 1; transition: opacity 0.3s;}
.ͼ1 [class^="cm-wf-debug-part-queued"] {--color-bg: repeating-linear-gradient(-55deg, var(--color-bg-main), var(--color-bg-main) 10px, var(--color-bg-secondary) 10px, var(--color-bg-secondary) 20px);}
.ͼ1 [class^="cm-wf-debug-part-checking"] {background-size: 100% 10px; --color-bg: repeating-linear-gradient(to bottom, var(--color-bg-main), var(--color-bg-main) 50%, var(--color-bg-secondary) 50%, var(--color-bg-secondary));}
.ͼ1 [class^="cm-wf-debug-part-checked"] {--color-bg: repeating-linear-gradient(to right, var(--color-bg-main), var(--color-bg-main) 6px, var(--color-bg-secondary) 2px, var(--color-bg-secondary) 8px);}
.ͼ1 [class^="cm-wf-debug-part-failed"] {--color-bg: repeating-linear-gradient(65deg, var(--color-bg-main), var(--color-bg-main) 12px, var(--color-bg-secondary) 12px, var(--color-bg-secondary) 24px);}
.ͼ1 [class^="cm-wf-debug-part-ignored"] {--color-bg: repeating-linear-gradient(12deg, var(--color-bg-main), var(--color-bg-main) 2px, var(--color-bg-secondary) 2px, var(--color-bg-secondary) 4px);}
.ͼ1 [class^="cm-wf-debug-part-ignored"]:hover::before {text-decoration: none;}
.ͼ1 [class^="cm-wf-debug-part-cached"] {--color-bg: hsl(var(--color-bg-h) var(--color-bg-s) var(--color-bg-l));}
.ͼ1 [class^="cm-wf-debug-part-"] * {background: transparent !important;}
